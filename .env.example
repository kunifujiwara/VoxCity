# Copy to .env (untracked) and adjust for your machine.
# Real environment variables always override these.

# ---- Windows native dev example ----
# Base data directory (defaults to app/data when unset).
# VOXCITY_DATA_DIR=C:\Users\you\voxcity-data
# Absolute path to the PLATEAU CityGML dataset directory.
# CITYGML_PATH=C:\Users\you\OneDrive\00_Codes\python\VoxelCity\app\data\plateau\13100_tokyo23-ku_2020_citygml_3_2_op

# ---- Linux / Docker example (normally set via docker-compose, shown for reference) ----
# VOXCITY_DATA_DIR=/work-voxcity/data
# VOXCITY_OUTPUT_DIR=/work-voxcity/output
# CITYGML_PATH=/work-voxcity/data/plateau/13100_tokyo23-ku_2022_citygml_1_2_op
# VOXCITY_FRONTEND_DIST=/app/app/frontend/dist

# ---- Optional overrides ----
# DEFAULT_TOKYO_EPW=/abs/path/to/JPN_TK_Tokyo-Chiyoda.476620_TMYx.epw
# NDSM_COG_PATH=/abs/path/to/ndsm_cog.tif

# ---- Session / runtime (defaults shown) ----
# VOXCITY_SESSION_MAX_UPLOAD_MB=500
# GEE_PROJECT=your-earth-engine-project
